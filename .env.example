# ──────────────────────────────────────────────────────────────────────────
# 9router combo env — copy to .env and edit
# ──────────────────────────────────────────────────────────────────────────
# NINE_ROUTER_BASE is the URL headroom uses to reach 9router.
# Default: assumes 9router runs on the host and docker host-gateway mapping
# resolves host.docker.internal → 127.0.0.1.
#
# On Linux without host.docker.internal, switch the service to network_mode:
# host and set NINE_ROUTER_BASE=http://127.0.0.1:20128
#
# On a remote dev box, set NINE_ROUTER_BASE=http://<host-ip>:20128
# ──────────────────────────────────────────────────────────────────────────

NINE_ROUTER_BASE=http://host.docker.internal:20128
